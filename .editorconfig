# editorconfig.org
root = true

[*]
charset = utf-8
end_of_line = lf
indent_size = 2
indent_style = space
insert_final_newline = true
trim_trailing_whitespace = true

# JavaScript/TypeScript files
[*.{js,jsx,ts,tsx}]

# JSON files
[*.json]

# YAML files
[*.{yml,yaml}]

# Markdown files
[*.md]
trim_trailing_whitespace = false

# CSS/SCSS files
[*.{css,scss}]

# HTML files
[*.html]

# Package files
[package.json]

# Configuration files
[.prettierrc.json,.babelrc,.oxfmtrc.json,.commitlint.config.cjs,.oxfmtrc.json,.knip.config.ts]

# Documentation
[*.{txt,md,markdown}]
trim_trailing_whitespace = false

# Minified files
[*.min.{js,css}]
indent_style = none
indent_size = 0
trim_trailing_whitespace = false
insert_final_newline = false

# Test files
[*.{spec,test}.{js,jsx,ts,tsx}]

# GraphQL files
[*.{graphql,gql}]

# Shell scripts
[*.{sh,bash}]
end_of_line = lf

# Docker files
[Dockerfile]
indent_size = 4

# Git config
[.gitattributes,.gitignore]

# Lock files
[package-lock.json,yarn.lock]
trim_trailing_whitespace = false

# Environment files
[.env*]
trim_trailing_whitespace = false
