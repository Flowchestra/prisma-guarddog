{
  "name": "@flowchestra/prisma-guarddog-core",
  "version": "0.1.0-alpha.10",
  "description": "Core API for prisma-guarddog: defineClaims, defineDbRoles, defineAppRoles, resources, Guarddog constructor, and policy builders",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Flowchestra/prisma-guarddog.git",
    "directory": "packages/core"
  },
  "keywords": [
    "prisma",
    "postgres",
    "rls",
    "policy",
    "compiler"
  ],
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./config": {
      "types": "./src/config.ts",
      "import": "./src/config.ts",
      "default": "./src/config.ts"
    }
  },
  "files": [
    "dist",
    "src",
    "README.md"
  ],
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "type-check": "tsgo --noEmit",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest --passWithNoTests",
    "clean": "rm -rf dist .turbo"
  },
  "devDependencies": {
    "@prisma/client": "^6.0.0",
    "prisma": "^6.0.0"
  },
  "publishConfig": {
    "access": "restricted",
    "main": "./dist/index.cjs",
    "module": "./dist/index.mjs",
    "types": "./dist/index.d.mts",
    "exports": {
      ".": {
        "types": "./dist/index.d.mts",
        "import": "./dist/index.mjs",
        "require": "./dist/index.cjs"
      },
      "./config": {
        "types": "./dist/config.d.mts",
        "import": "./dist/config.mjs",
        "require": "./dist/config.cjs"
      }
    },
    "registry": "https://npm.pkg.github.com"
  }
}
