{
  "name": "@prisma-guarddog/testing-postgres",
  "version": "0.0.0",
  "description": "Real-Postgres verification harness for prisma-guarddog: withDbRole, withClaims, assertion helpers",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Flowchestra/prisma-guarddog.git",
    "directory": "packages/testing-postgres"
  },
  "keywords": [
    "postgres",
    "rls",
    "testing",
    "vitest"
  ],
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    }
  },
  "files": [
    "dist",
    "src",
    "README.md"
  ],
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "type-check": "tsgo --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "clean": "rm -rf dist .turbo"
  },
  "dependencies": {
    "@prisma-guarddog/core": "workspace:*"
  },
  "peerDependencies": {
    "@prisma/client": ">=6.0.0",
    "pg": ">=8.0.0"
  },
  "devDependencies": {
    "@prisma/client": "^6.0.0",
    "@types/pg": "^8.11.10",
    "pg": "^8.13.1",
    "prisma": "^6.0.0"
  },
  "publishConfig": {
    "access": "public",
    "main": "./dist/index.cjs",
    "module": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "import": "./dist/index.js",
        "require": "./dist/index.cjs"
      }
    }
  }
}
