{
  "name": "@prisma-guarddog/lint",
  "version": "0.0.0",
  "description": "Coverage lint for prisma-guarddog: every Prisma model must have policy(), noPolicy(), or importedRawPolicy()",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Flowchestra/prisma-guarddog.git",
    "directory": "packages/lint"
  },
  "keywords": [
    "prisma",
    "rls",
    "lint",
    "coverage"
  ],
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    }
  },
  "files": [
    "dist",
    "src",
    "README.md"
  ],
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "type-check": "tsgo --noEmit",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest --passWithNoTests",
    "clean": "rm -rf dist .turbo"
  },
  "dependencies": {
    "@prisma-guarddog/core": "workspace:*",
    "@prisma-guarddog/importer-prisma": "workspace:*"
  },
  "peerDependencies": {
    "@prisma/internals": ">=6.0.0"
  },
  "devDependencies": {
    "@prisma/internals": "^6.0.0"
  },
  "publishConfig": {
    "access": "public",
    "main": "./dist/index.cjs",
    "module": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "import": "./dist/index.js",
        "require": "./dist/index.cjs"
      }
    }
  }
}
