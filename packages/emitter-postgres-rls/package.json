{
  "name": "@flowchestra/prisma-guarddog-emitter-postgres-rls",
  "version": "0.1.0-alpha.13",
  "description": "Postgres RLS DDL emitter for prisma-guarddog: CREATE POLICY, ENABLE/FORCE ROW LEVEL SECURITY, table-level REVOKE",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Flowchestra/prisma-guarddog.git",
    "directory": "packages/emitter-postgres-rls"
  },
  "keywords": [
    "prisma",
    "postgres",
    "rls",
    "policy",
    "emitter"
  ],
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts",
      "default": "./src/index.ts"
    }
  },
  "files": [
    "dist",
    "src",
    "README.md"
  ],
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "type-check": "tsgo --noEmit",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest --passWithNoTests",
    "clean": "rm -rf dist .turbo"
  },
  "dependencies": {
    "@flowchestra/prisma-guarddog-core": "workspace:*"
  },
  "publishConfig": {
    "access": "restricted",
    "main": "./dist/index.cjs",
    "module": "./dist/index.mjs",
    "types": "./dist/index.d.mts",
    "exports": {
      ".": {
        "types": "./dist/index.d.mts",
        "import": "./dist/index.mjs",
        "require": "./dist/index.cjs"
      }
    },
    "registry": "https://npm.pkg.github.com"
  }
}
