{
  "name": "prisma-guarddog",
  "version": "0.0.0",
  "description": "CLI for prisma-guarddog: emit, diff, migrate, import",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Flowchestra/prisma-guarddog.git",
    "directory": "packages/cli"
  },
  "keywords": [
    "prisma",
    "postgres",
    "rls",
    "cli",
    "migrations"
  ],
  "type": "module",
  "bin": {
    "guarddog": "./src/bin.ts",
    "prisma-guarddog": "./src/bin.ts",
    "prisma-guarddog-generator": "./src/generator-bin.ts"
  },
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    }
  },
  "files": [
    "dist",
    "src",
    "README.md"
  ],
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "type-check": "tsgo --noEmit",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest --passWithNoTests",
    "clean": "rm -rf dist .turbo"
  },
  "dependencies": {
    "@prisma-guarddog/core": "workspace:*",
    "@prisma-guarddog/emitter-postgres-rls": "workspace:*",
    "@prisma-guarddog/emitter-postgres-column-privileges": "workspace:*",
    "@prisma-guarddog/importer-prisma": "workspace:*",
    "@prisma-guarddog/importer-postgres": "workspace:*",
    "@prisma-guarddog/lint": "workspace:*",
    "commander": "^13.0.0",
    "jiti": "^2.5.0",
    "picocolors": "^1.1.1",
    "@prisma/generator-helper": "^6.0.0"
  },
  "peerDependencies": {
    "@prisma/internals": ">=6.0.0",
    "prisma": ">=6.0.0"
  },
  "devDependencies": {
    "@prisma/internals": "^6.0.0",
    "@types/node": "^22.10.0",
    "prisma": "^6.0.0"
  },
  "publishConfig": {
    "access": "public",
    "main": "./dist/index.cjs",
    "module": "./dist/index.mjs",
    "types": "./dist/index.d.mts",
    "exports": {
      ".": {
        "types": "./dist/index.d.mts",
        "import": "./dist/index.mjs",
        "require": "./dist/index.cjs"
      }
    },
    "bin": {
      "guarddog": "./dist/bin.cjs",
      "prisma-guarddog": "./dist/bin.cjs",
      "prisma-guarddog-generator": "./dist/generator-bin.cjs"
    }
  }
}
