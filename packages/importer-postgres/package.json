{
  "name": "@flowchestra/prisma-guarddog-importer-postgres",
  "version": "0.1.0-alpha.14",
  "description": "Postgres pg_policies + column privileges importer for prisma-guarddog (scaffold mode)",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Flowchestra/prisma-guarddog.git",
    "directory": "packages/importer-postgres"
  },
  "keywords": [
    "postgres",
    "pg_policies",
    "rls",
    "importer",
    "scaffold"
  ],
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts",
      "default": "./src/index.ts"
    }
  },
  "files": [
    "dist",
    "src",
    "README.md"
  ],
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "type-check": "tsgo --noEmit",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest --passWithNoTests",
    "clean": "rm -rf dist .turbo"
  },
  "dependencies": {
    "@flowchestra/prisma-guarddog-core": "workspace:*"
  },
  "peerDependencies": {
    "pg": ">=8.0.0"
  },
  "devDependencies": {
    "@types/pg": "^8.11.10",
    "pg": "^8.13.1"
  },
  "publishConfig": {
    "access": "restricted",
    "main": "./dist/index.cjs",
    "module": "./dist/index.mjs",
    "types": "./dist/index.d.mts",
    "exports": {
      ".": {
        "types": "./dist/index.d.mts",
        "import": "./dist/index.mjs",
        "require": "./dist/index.cjs"
      }
    },
    "registry": "https://npm.pkg.github.com"
  }
}
