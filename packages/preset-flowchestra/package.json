{
  "name": "@flowchestra/prisma-guarddog-preset",
  "version": "0.1.0-alpha.15",
  "description": "Flowchestra preset for prisma-guarddog: createFlowchestraGuarddog with WorkOS claim shape and app_user/app_system role hierarchy",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Flowchestra/prisma-guarddog.git",
    "directory": "packages/preset-flowchestra"
  },
  "keywords": [
    "prisma",
    "rls",
    "flowchestra",
    "workos",
    "preset"
  ],
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts",
      "default": "./src/index.ts"
    }
  },
  "files": [
    "dist",
    "src",
    "README.md"
  ],
  "scripts": {
    "build": "tsdown",
    "dev": "tsdown --watch",
    "type-check": "tsgo --noEmit",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest --passWithNoTests",
    "clean": "rm -rf dist .turbo"
  },
  "dependencies": {
    "@flowchestra/prisma-guarddog-core": "workspace:*"
  },
  "peerDependencies": {
    "@prisma/client": ">=6.0.0"
  },
  "devDependencies": {
    "@prisma/client": "^6.0.0",
    "prisma": "^6.0.0"
  },
  "publishConfig": {
    "access": "restricted",
    "main": "./dist/index.cjs",
    "module": "./dist/index.mjs",
    "types": "./dist/index.d.mts",
    "exports": {
      ".": {
        "types": "./dist/index.d.mts",
        "import": "./dist/index.mjs",
        "require": "./dist/index.cjs"
      }
    },
    "registry": "https://npm.pkg.github.com"
  }
}
