# === Workspace (Turborepo + pnpm) ===
prefer-workspace-packages=true
link-workspace-packages=true
shared-workspace-lockfile=true

# === Performance ===
network-concurrency=8
workers=4
progress=false
package-import-method=hardlink
prefer-offline=true

# === Resolution ===
resolution-mode=highest
auto-install-peers=true
strict-peer-dependencies=false
shamefully-hoist=false

# === Network ===
fetch-retries=2
fetch-retry-mintimeout=5000
fetch-retry-maxtimeout=15000
fetch-timeout=30000

# === Module resolution ===
node-linker=isolated
enable-pre-post-scripts=false

# === Logging ===
loglevel=error

# === Registry ===
registry=https://registry.npmjs.org/
strict-ssl=true

# Route the @flowchestra scope to GitHub Packages. Consumers and publishers
# both pick up this line; the (sensitive) _authToken is provided per
# environment via either ~/.npmrc, a local untracked .npmrc, or CI secrets.
# See RELEASING.md for the publisher setup; consumers see the install
# section of the root README.
@flowchestra:registry=https://npm.pkg.github.com

# === CI ===
frozen-lockfile=true
side-effects-cache=true
